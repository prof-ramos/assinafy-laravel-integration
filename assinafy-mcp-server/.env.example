# Assinafy MCP Server — Environment Variables
# Copy this file to .env and fill in your credentials

# REQUIRED: Assinafy API Key (never commit this)
ASSINAFY_API_KEY=sk_your_api_key_here

# REQUIRED: Assinafy Account ID
ASSINAFY_ACCOUNT_ID=acc_your_account_id_here

# Environment: sandbox (default) or production
ASSINAFY_ENV=sandbox

# HTTP timeout in milliseconds (default: 30000)
ASSINAFY_TIMEOUT_MS=30000

# Transport: stdio (default) or http
TRANSPORT=stdio

# HTTP port (only used when TRANSPORT=http)
PORT=3100
