# ============================================================================
# E2E Test Environment Configuration
# ============================================================================
# Copy this file to .env.testing and update with your test values

# ============================================================================
# Laravel Application
# ============================================================================
APP_URL=http://localhost:8000
APP_ENV=testing

# ============================================================================
# Database (Testing)
# ============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=assinafy_testing
DB_USERNAME=root
DB_PASSWORD=

# ============================================================================
# Assinafy API (Sandbox)
# ============================================================================
ASSINAFY_API_KEY=sk_test_your_api_key_here
ASSINAFY_ACCOUNT_ID=acc_test_your_account_id_here
ASSINAFY_ENV=sandbox

# ============================================================================
# Assinafy Webhook
# ============================================================================
ASSINAFY_WEBHOOK_SECRET=whsec_test_your_webhook_secret_here

# ============================================================================
# Test Users
# ============================================================================
TEST_USER_EMAIL=e2e-test@example.com
TEST_USER_PASSWORD=TestPassword123!
ADMIN_USER_EMAIL=admin@example.com
ADMIN_USER_PASSWORD=AdminPassword123!

# ============================================================================
# Test Configuration
# ============================================================================
# Parallel workers for local testing
TEST_WORKERS=2

# CI configuration
CI_MAX_WORKERS=2

# Browser timeout (ms)
BROWSER_TIMEOUT=30000

# ============================================================================
# External Services
# ============================================================================
# Mailtrap for email testing (optional)
MAILTRAP_API_KEY=

# S3/Storage for file uploads (optional - use local for E2E)
FILESYSTEM_DRIVER=local
